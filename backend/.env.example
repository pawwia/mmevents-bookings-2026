# MMEvent backend — konfiguracja środowiska
# Na LH.pl plik .env umieść w katalogu backendu (poza public_html jeśli to możliwe).

APP_ENV=production            # production | development
APP_DEBUG=0

DB_HOST=localhost
DB_PORT=3306
DB_NAME=mmevent
DB_USER=mmevent
DB_PASS=

# Sekret JWT — wygeneruj: openssl rand -hex 32
JWT_SECRET=
JWT_TTL=86400

# Adres frontendu (CORS). Po wdrożeniu zmień też ustawienie app.frontend_url w CRM.
FRONTEND_URL=http://localhost:5173

# Sekret chroniący endpointy cron uruchamiane przez HTTP (LH.pl cron URL)
CRON_SECRET=
